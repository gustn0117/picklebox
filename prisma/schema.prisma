// PICKLEBOX CMS 데이터 모델. SQLite + Prisma.
generator client {
  provider = "prisma-client-js"
  // 로컬(native) + Docker alpine 런타임(openssl 3.0.x musl) 엔진 모두 생성
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 각 페이지 상단/메인 배너 이미지 + 문구
model Banner {
  id        Int      @id @default(autoincrement())
  page      String   @default("home") // home, about, events ...
  imageUrl  String?
  title     String?
  subtitle  String?
  linkUrl   String?
  visible   Boolean  @default(true)
  publishAt DateTime? // 예약 공개 시각(비면 즉시)
  deletedAt DateTime? // 휴지통(값 있으면 숨김)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 이벤트 (라인업 + 일정)
model Event {
  id          Int      @id @default(autoincrement())
  kind        String   @default("lineup") // lineup | schedule
  titleEn     String?
  titleKo     String
  description String   @default("")
  period      String?  // 예: 상반기, 매월, 상시
  imageUrl    String?
  visible     Boolean  @default(true)
  publishAt DateTime? // 예약 공개 시각(비면 즉시)
  deletedAt DateTime? // 휴지통(값 있으면 숨김)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 아카데미 프로그램
model AcademyProgram {
  id          Int      @id @default(autoincrement())
  titleEn     String?
  titleKo     String
  description String   @default("")
  imageUrl    String?
  visible     Boolean  @default(true)
  publishAt DateTime? // 예약 공개 시각(비면 즉시)
  deletedAt DateTime? // 휴지통(값 있으면 숨김)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 여행 상품 (이미지·일정·가격·상세·예약 링크)
model Tour {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @default("")
  period      String?
  imageUrl    String?
  linkUrl     String?
  price       Int? // 비우면 가격 미표시
  schedule    String   @default("") // 일정 상세(줄바꿈 구분)
  bookingUrl  String? // 예약 링크
  visible     Boolean  @default(true)
  publishAt DateTime? // 예약 공개 시각(비면 즉시)
  deletedAt DateTime? // 휴지통(값 있으면 숨김)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 굿즈 (카드형: 이미지·가격·설명·구매 링크)
model Goods {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  imageUrl    String?
  buyUrl      String   @default("")
  price       Int? // 비우면 가격 미표시
  soldOut     Boolean  @default(false)
  visible     Boolean  @default(true)
  publishAt DateTime? // 예약 공개 시각(비면 즉시)
  deletedAt DateTime? // 휴지통(값 있으면 숨김)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 파트너사 (로고 목록)
model Partner {
  id          Int      @id @default(autoincrement())
  name        String
  logoUrl     String?
  linkUrl     String?
  description String   @default("")
  visible     Boolean  @default(true)
  publishAt DateTime? // 예약 공개 시각(비면 즉시)
  deletedAt DateTime? // 휴지통(값 있으면 숨김)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 저널 (기사 링크 또는 유튜브 영상)
model JournalPost {
  id         Int      @id @default(autoincrement())
  category   String   @default("Culture")
  title      String
  type       String   @default("article") // article | video | soon
  articleUrl String?
  videoIds   String   @default("[]") // JSON 배열 문자열 (유튜브 ID 목록)
  soon       Boolean  @default(false)
  visible    Boolean  @default(true)
  publishAt DateTime? // 예약 공개 시각(비면 즉시)
  deletedAt DateTime? // 휴지통(값 있으면 숨김)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 사진 / 갤러리
model Photo {
  id        Int      @id @default(autoincrement())
  imageUrl  String
  caption   String?
  album     String?
  visible   Boolean  @default(true)
  publishAt DateTime? // 예약 공개 시각(비면 즉시)
  deletedAt DateTime? // 휴지통(값 있으면 숨김)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 사이트 문구 + 전역 정보 — 페이지별로 묶어(group) 관리. 값만 수정(추가·삭제 불가).
model SiteCopy {
  id        Int      @id @default(autoincrement())
  key       String   @unique // 예: home.hero.tagline1
  group     String   @default("site") // site | home | about | founder | community | partners | events | journal | visit | goods | tours
  label     String // 관리자 표시명(어디 문구인지)
  value     String   @default("")
  kind      String   @default("text") // text | textarea | url
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

// 수정·삭제 직전 상태 스냅샷 (되돌리기용). 항목당 최근 20건 유지.
model Revision {
  id        Int      @id @default(autoincrement())
  model     String // 관리 모델 slug (events, goods …)
  recordId  Int
  snapshot  String // JSON 문자열
  action    String   @default("update") // update | delete
  createdAt DateTime @default(now())

  @@index([model, recordId])
}
